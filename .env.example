# Server
PORT=3000

# Site identity (shown in notifications and Discord messages)
SITE_NAME=Your Name
SITE_URL=https://your-server.com

# Auth
API_KEY=your-stream-deck-secret-key
ADMIN_PASSWORD=your-admin-password

# Discord webhook (optional)
# Create one in Discord: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Web Push / VAPID keys (optional)
# Generate with: npm run generate-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=you@example.com
